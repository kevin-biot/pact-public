{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lane2.example/schemas/delivery-profile.schema.json",
  "title": "Delivery Profile",
  "description": "Execution-mode policy profile for promotion-gate delivery controls.",
  "type": "object",
  "required": [
    "schema_version",
    "profile_id",
    "profile_tier",
    "allowed_delivery_modes",
    "require_signature",
    "require_trust_config",
    "fail_open_allowed"
  ],
  "properties": {
    "schema_version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+$"
    },
    "profile_id": {
      "type": "string",
      "minLength": 1
    },
    "profile_tier": {
      "type": "string",
      "enum": [
        "production",
        "pilot",
        "lab"
      ]
    },
    "allowed_delivery_modes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "enum": [
          "hosted_mcp",
          "local_binary"
        ]
      }
    },
    "require_signature": {
      "type": "boolean"
    },
    "require_trust_config": {
      "type": "boolean"
    },
    "fail_open_allowed": {
      "type": "boolean"
    },
    "hosted_endpoint": {
      "type": "string",
      "format": "uri"
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "profile_tier": {
            "const": "production"
          }
        },
        "required": [
          "profile_tier"
        ]
      },
      "then": {
        "properties": {
          "fail_open_allowed": {
            "const": false
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
