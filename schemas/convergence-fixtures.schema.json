{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ontology.example.com/schemas/convergence-fixtures.schema.json",
  "title": "Ontology Convergence Fixtures (convergence.json)",
  "description": "Schema for deterministic phrase-to-intent convergence fixtures and quality thresholds (ADR-024).",
  "type": "object",
  "required": ["schema_version", "domain", "cases"],
  "properties": {
    "schema_version": {
      "type": "string",
      "const": "1.0",
      "description": "Schema version for fixture contract."
    },
    "domain": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[a-z0-9][a-z0-9_-]*$",
      "description": "Domain name; must match pack domain."
    },
    "thresholds": {
      "type": "object",
      "description": "Optional quality gates for fixture execution.",
      "properties": {
        "overall_min_pass_rate": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Minimum pass rate required across all cases."
        },
        "require_critical_pass": {
          "type": "boolean",
          "description": "Whether all critical cases must pass."
        }
      },
      "additionalProperties": false
    },
    "cases": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["phrase", "expect"],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "phrase": {
            "type": "string",
            "minLength": 1
          },
          "expect": {
            "type": "string",
            "pattern": "^[a-z0-9]+(\\.[a-z0-9_]+){1,}\\.v[0-9]+$",
            "description": "Expected canonical intent class."
          },
          "critical": {
            "type": "boolean"
          },
          "notes": {
            "type": "string"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
