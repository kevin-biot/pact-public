    },
    {
      "id": "ais_balances_read",
      "phrase": "retrieve account balances",
      "expect": "openbanking.balance.read.v1",
      "critical": true
    },
    {
      "id": "ais_transactions_read",
      "phrase": "fetch transaction history",
      "expect": "openbanking.transaction.read.v1",
      "critical": true
    }
  ]
}
