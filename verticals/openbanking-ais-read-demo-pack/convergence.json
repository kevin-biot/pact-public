{
  "schema_version": "1.0",
  "domain": "openbanking-ais-read-demo",
  "thresholds": {
    "overall_min_pass_rate": 1.0,
    "require_critical_pass": true
  },
  "cases": [
    {
      "id": "ais_accounts_read",
      "phrase": "show my account list",
      "expect": "openbanking.account.read.v1",
