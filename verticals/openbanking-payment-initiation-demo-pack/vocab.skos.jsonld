    },
    {
      "@id": "ob:payment/cancel",
      "@type": "skos:Concept",
      "skos:prefLabel": "Cancel Payment",
      "skos:altLabel": ["revoke payment", "payment cancellation"],
      "skos:broader": "ob:family/payments"
    }
  ]
