@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix fhiret: <https://lane2.example/ontology/fhir-encounter-transitions/> .

fhiret:IntentShape
  a sh:NodeShape ;
  sh:targetClass fhiret:Intention ;
  sh:property [
    sh:path fhiret:intentClass ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:message "intentClass is required"
  ] ;
  sh:property [
    sh:path fhiret:resourceType ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:message "resourceType is required"
  ] ;
  sh:property [
    sh:path fhiret:encounterRef ;
    sh:datatype xsd:string ;
    sh:minCount 1 ;
    sh:message "encounterRef is required"
  ] .
