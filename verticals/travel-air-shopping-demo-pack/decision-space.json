{
  "schema_version": "1.0",
  "domain": "travel-air-shopping",
  "pack_id": "travel-air-shopping-demo-0.1.0",
  "version": "0.1.0",
  "out_of_scope_behavior": "escalate",
  "state_model": {
    "states": [
      "ingress",
      "validated",
      "classified",
      "responded",
      "rejected",
      "escalated"
    ],
    "initial_state": "ingress",
    "terminal_states": [
      "responded",
      "rejected",
      "escalated"
    ]
  },
  "admissible_intents": [
    {
      "intent_class": "travel.flight.shopping.v1",
      "allowed_states": [
        "ingress",
        "validated",
        "classified"
      ],
      "required_fact_types": [
        "travel_request"
      ],
      "transition_ids": [
        "validate_request",
        "classify_request",
        "respond_request"
      ]
    }
  ],
  "admissible_facts": [
    {
      "fact_type": "travel_request",
      "schema_ref": "urn:travel:travel-air-shopping:request:v1",
      "additional_properties": "deny",
      "field_constraints": [
        {
          "path": "originLocationCode",
          "datatype": "string",
          "required": true,
          "pattern": "^[A-Z]{3}$"
        },
        {
          "path": "destinationLocationCode",
          "datatype": "string",
          "required": true,
          "pattern": "^[A-Z]{3}$"
        },
        {
          "path": "departureDate",
          "datatype": "string",
          "required": true,
          "format": "date"
        },
        {
          "path": "returnDate",
          "datatype": "string",
          "required": false,
          "format": "date"
        },
        {
          "path": "adults",
          "datatype": "integer",
          "required": true,
          "format": "integer"
        },
        {
          "path": "travelClass",
          "datatype": "string",
          "required": false,
          "allowed_values": [
            "ECONOMY",
            "PREMIUM_ECONOMY",
            "BUSINESS",
            "FIRST"
          ]
        },
        {
          "path": "includedAirlineCodes",
          "datatype": "string",
          "required": false,
          "pattern": "^[0-9A-Z]{2}(,[0-9A-Z]{2})*$"
        },
        {
          "path": "excludedAirlineCodes",
          "datatype": "string",
          "required": false,
          "pattern": "^[0-9A-Z]{2}(,[0-9A-Z]{2})*$"
        },
        {
          "path": "currencyCode",
          "datatype": "string",
          "required": false,
          "pattern": "^[A-Z]{3}$"
        },
        {
          "path": "maxPrice",
          "datatype": "integer",
          "required": false,
          "format": "integer"
        },
        {
          "path": "data.flightOffers[].source",
          "datatype": "string",
          "required": true,
          "allowed_values": [
            "GDS",
            "NDC",
            "LTC",
            "EAC"
          ]
        },
        {
          "path": "OriginDestinationInformation.DepartureDateTime",
          "datatype": "string",
          "required": true,
          "format": "date-time"
        }
      ]
    }
  ],
  "admissible_transitions": [
    {
      "id": "validate_request",
      "from_state": "ingress",
      "intent_class": "travel.flight.shopping.v1",
      "to_state": "validated",
      "guard_refs": [
        "guard:payload_valid"
      ]
    },
    {
      "id": "classify_request",
      "from_state": "validated",
      "intent_class": "travel.flight.shopping.v1",
      "to_state": "classified",
      "guard_refs": [
        "guard:intent_mapped"
      ]
    },
    {
      "id": "respond_request",
      "from_state": "classified",
      "intent_class": "travel.flight.shopping.v1",
      "to_state": "responded",
      "guard_refs": [
        "guard:policy_permitted"
      ]
    },
    {
      "id": "handle_out_of_scope",
      "from_state": "ingress",
      "intent_class": "travel.flight.shopping.v1",
      "to_state": "escalated",
      "guard_refs": [
        "guard:intent_out_of_scope"
      ],
      "deontic": "must",
      "source_ref": "travel:governance:out-of-scope:v1"
    }
  ],
  "escalation_predicates": [
    {
      "predicate_id": "travel_out_of_scope",
      "trigger": "intent_out_of_scope",
      "description": "Hotel booking intent is outside the scoped air-shopping decision surface.",
      "routing": "escalate"
    }
  ]
}
