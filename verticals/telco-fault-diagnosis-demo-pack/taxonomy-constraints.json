{
  "decisionTypes": {
    "FaultDiagnosis": {
      "allow": [
        "fault.diagnosis.execute"
      ],
      "fieldPolicy": {
        "constraints.taskPriority": {
          "allow": [
            "High",
            "Low",
            "Medium"
          ],
          "required": true
        },
        "constraints.timeLimit": {
          "format": "duration",
          "required": false
        },
        "targetObject.identifier": {
          "maxLength": 64,
          "minLength": 8,
          "pattern": "^[A-Za-z0-9][A-Za-z0-9._:-]{7,63}$",
          "required": true
        },
        "taskContext.faultOccurrenceTime": {
          "format": "rfc3339",
          "required": true
        }
      }
    }
  },
  "version": "tax:v1"
}
