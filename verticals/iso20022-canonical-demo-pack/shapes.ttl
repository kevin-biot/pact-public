@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix iso: <https://lane2.example/ontology/iso20022/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ------------------------------------------------------------
# ISO 20022 canonical narrow demo SHACL profile.
# Scope: pacs.008.001.13 only.
# ------------------------------------------------------------

iso:CreditTransferPacs00800113Shape
  a sh:NodeShape ;
  sh:targetClass iso:msgtype\/pacs.008 ;
  sh:property [
    sh:path iso:messageVersion ;
    sh:datatype xsd:string ;
    sh:pattern "^001\\.13$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "messageVersion must be 001.13 for this narrow canonical demo"
  ] ;
  sh:property [
    sh:path iso:messageId ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Za-z0-9][A-Za-z0-9-]{5,34}$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "messageId is required"
  ] ;
  sh:property [
    sh:path iso:endToEndId ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Za-z0-9][A-Za-z0-9-]{5,34}$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "endToEndId is required"
  ] ;
  sh:property [
    sh:path iso:currency ;
    sh:datatype xsd:string ;
    sh:in ( "EUR" "USD" "GBP" "THB" "JPY" "CHF" "CAD" "AUD" "SGD" "HKD" "CNY" ) ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "currency must be a supported ISO 4217 code"
  ] ;
  sh:property [
    sh:path iso:amount ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0.01 ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "amount must be a positive decimal"
  ] ;
  sh:property [
    sh:path iso:debtorIBAN ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Z]{2}\\d{2}[A-Z0-9]{4,30}$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "debtorIBAN must be a valid IBAN"
  ] ;
  sh:property [
    sh:path iso:creditorIBAN ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Z]{2}\\d{2}[A-Z0-9]{4,30}$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "creditorIBAN must be a valid IBAN"
  ] ;
  sh:property [
    sh:path iso:debtorBIC ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "debtorBIC must be a valid BIC"
  ] ;
  sh:property [
    sh:path iso:creditorBIC ;
    sh:datatype xsd:string ;
    sh:pattern "^[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?$" ;
    sh:minCount 1 ;
    sh:maxCount 1 ;
    sh:message "creditorBIC must be a valid BIC"
  ] .
