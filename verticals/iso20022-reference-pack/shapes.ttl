@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix iso: <https://lane2.example/ontology/iso20022/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# -------------------------------------------------------------------
# ISO 20022 SHACL shapes — structural validation only.
# Behavioral/quality validation is handled by DOP rubrics (ADR-015).
# -------------------------------------------------------------------

# --- pacs.008: FI-to-FI Customer Credit Transfer ---
iso:CreditTransferShape
  a sh:NodeShape ;
  sh:targetClass iso:msgtype\/pacs.008 ;
  sh:property [
    sh:path iso:currency ;
    sh:in ( "EUR" "USD" "GBP" "THB" "JPY" "CHF" "CAD" "AUD" "SGD" "HKD" "CNY" ) ;
    sh:minCount 1 ;
    sh:message "currency must be a supported ISO 4217 code"
  ] ;
  sh:property [
    sh:path iso:amount ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0.01 ;
    sh:minCount 1 ;
    sh:message "amount must be a positive decimal"
  ] ;
  sh:property [
    sh:path iso:debtorIBAN ;
    sh:pattern "^[A-Z]{2}\\d{2}[A-Z0-9]{4,30}$" ;
    sh:message "debtorIBAN must be a valid IBAN"
  ] ;
  sh:property [
    sh:path iso:creditorIBAN ;
    sh:pattern "^[A-Z]{2}\\d{2}[A-Z0-9]{4,30}$" ;
    sh:message "creditorIBAN must be a valid IBAN"
  ] ;
  sh:property [
    sh:path iso:debtorBIC ;
    sh:pattern "^[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?$" ;
    sh:message "debtorBIC must be a valid BIC/SWIFT code"
  ] ;
  sh:property [
    sh:path iso:creditorBIC ;
    sh:pattern "^[A-Z]{4}[A-Z]{2}[A-Z0-9]{2}([A-Z0-9]{3})?$" ;
    sh:message "creditorBIC must be a valid BIC/SWIFT code"
  ] .

# --- pacs.002: FI-to-FI Payment Status Report ---
iso:PaymentStatusReportShape
  a sh:NodeShape ;
  sh:targetClass iso:msgtype\/pacs.002 ;
  sh:property [
    sh:path iso:reasonCode ;
    sh:pattern "^[A-Z]{2,4}\\d{2}$" ;
    sh:message "reasonCode must match ISO 20022 format (2-4 letters + 2 digits)"
  ] ;
  sh:property [
    sh:path iso:originalMessageType ;
    sh:pattern "^(pacs|pain|camt|acmt)\\.\\d{3}$" ;
    sh:message "originalMessageType must be a valid ISO 20022 message type"
  ] .

# --- pain.001: Customer Credit Transfer Initiation ---
iso:PaymentInitiationShape
  a sh:NodeShape ;
  sh:targetClass iso:msgtype\/pain.001 ;
  sh:property [
    sh:path iso:currency ;
    sh:in ( "EUR" "USD" "GBP" "THB" "JPY" "CHF" "CAD" "AUD" "SGD" "HKD" "CNY" ) ;
    sh:minCount 1 ;
    sh:message "currency is required for payment initiation"
  ] ;
  sh:property [
    sh:path iso:amount ;
    sh:datatype xsd:decimal ;
    sh:minInclusive 0.01 ;
    sh:minCount 1 ;
    sh:message "amount must be a positive decimal"
  ] ;
  sh:property [
    sh:path iso:creditorIBAN ;
    sh:pattern "^[A-Z]{2}\\d{2}[A-Z0-9]{4,30}$" ;
    sh:minCount 1 ;
    sh:message "creditorIBAN is required and must be a valid IBAN"
  ] .

# --- camt.053: Bank-to-Customer Statement ---
iso:AccountStatementShape
  a sh:NodeShape ;
  sh:targetClass iso:msgtype\/camt.053 ;
  sh:property [
    sh:path iso:accountIBAN ;
    sh:pattern "^[A-Z]{2}\\d{2}[A-Z0-9]{4,30}$" ;
    sh:minCount 1 ;
    sh:message "accountIBAN is required for account statements"
  ] ;
  sh:property [
    sh:path iso:statementDate ;
    sh:datatype xsd:date ;
    sh:minCount 1 ;
    sh:message "statementDate is required and must be a valid date"
  ] .
