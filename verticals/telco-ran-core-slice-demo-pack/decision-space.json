{
  "schema_version": "1.0",
  "domain": "telco-ran-core-slice",
  "pack_id": "pack-ran-core-slice-0.1.0",
  "version": "0.1.0",
  "out_of_scope_behavior": "escalate",
  "state_model": {
    "states": ["ingress", "validated", "classified", "responded", "rejected", "escalated"],
    "initial_state": "ingress",
    "terminal_states": ["responded", "rejected", "escalated"]
  },
  "admissible_intents": [
    {
      "intent_class": "telco.ran.slice.attach.v1",
      "allowed_states": ["ingress", "validated", "classified"],
      "required_fact_types": ["ran_slice_request"],
      "transition_ids": ["validate_request", "classify_request", "respond_request"]
    }
  ],
  "admissible_facts": [
    {
      "fact_type": "ran_slice_request",
      "schema_ref": "urn:telco:ran-core-slice:request:v1",
      "additional_properties": "allow",
      "field_constraints": [
        {
          "path": "sliceId",
          "datatype": "string",
          "required": true,
          "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
        },
        {
          "path": "target",
          "datatype": "string",
          "required": true,
          "allowed_values": [
            "gnbdufunction",
            "gnbcucpfunction",
            "nrcelldu",
            "nrcellcu",
            "amffunction",
            "smffunction",
            "upffunction",
            "nwdafunction"
          ]
        }
      ]
    }
  ]
}
